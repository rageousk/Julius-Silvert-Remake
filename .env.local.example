# ─────────────────────────────────────────────────────────────
# Julius Silvert B2B — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ─────────────────────────────────────────────────────────────

# Required — NextAuth
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-random-secret-here
NEXTAUTH_URL=http://localhost:3000

# ── Google OAuth ──────────────────────────────────────────────
# 1. Go to https://console.cloud.google.com
# 2. Create a project → APIs & Services → Credentials
# 3. Create OAuth 2.0 Client ID (Web application)
# 4. Add Authorized redirect URI: http://localhost:3000/api/auth/callback/google
# 5. Copy Client ID and Client Secret below
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Microsoft / Azure AD OAuth ────────────────────────────────
# 1. Go to https://portal.azure.com
# 2. Azure Active Directory → App registrations → New registration
# 3. Set Redirect URI: http://localhost:3000/api/auth/callback/azure-ad
# 4. Certificates & secrets → New client secret
# 5. Copy Application (client) ID, Client Secret, and Directory (tenant) ID below
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=common
# Use "common" to allow any Microsoft account,
# or set your specific tenant ID to restrict to one org.

# ── Optional: shared demo / reviewer login (email & password only) ────────────
# Set both on the server (e.g. Vercel env). Email must satisfy allowed domains
# in lib/auth-domains.ts. Password is never shown in the UI or committed.
# DEMO_AUTH_EMAIL=demo@juliussilvert.com
# DEMO_AUTH_PASSWORD=
